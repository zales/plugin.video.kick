<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.zales.kick" name="KICK.com Repository" version="1.0.0" provider-name="zales">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>

    <extension point="xbmc.addon.repository" name="KICK.com Repository">
        <info compressed="false">https://kodi.zales.dev/addons.xml</info>
        <checksum>https://kodi.zales.dev/addons.xml.md5</checksum>
